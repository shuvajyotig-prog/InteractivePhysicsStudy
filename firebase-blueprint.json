{
  "entities": {
    "Attempt": {
      "title": "Test Attempt",
      "description": "A student's attempt at a pressure test",
      "type": "object",
      "properties": {
        "topicId": { "type": "string" },
        "score": { "type": "integer" },
        "total": { "type": "integer" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "date": { "type": "string", "format": "date-time" },
        "mistakes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["topicId", "score", "total", "difficulty", "date", "mistakes"]
    },
    "User": {
      "title": "User Profile",
      "description": "Metadata about the user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "AICache": {
      "title": "AI Content Cache",
      "description": "Stored deep dives and formula explanations",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["dive", "formula", "solve"] },
        "key": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "type", "key", "createdAt"]
    },
    "feedback": {
      "title": "User Feedback",
      "description": "Feedback on AI tutor responses",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "input": { "type": "string" },
        "response": { "type": "string" },
        "isPositive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "topic", "input", "response", "isPositive", "createdAt"]
    }
  },
  "firestore": {
    "/feedback/{feedbackId}": {
      "schema": "feedback",
      "description": "AI Tutor feedback entries"
    },
    "/ai_cache/{cacheId}": {
      "schema": "AICache",
      "description": "Global cache for AI-generated content"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/attempts/{attemptId}": {
      "schema": "Attempt",
      "description": "History of test attempts per user"
    }
  }
}
