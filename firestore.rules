rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    
    function isValidCache(data) {
      return data.keys().hasAll(['content', 'type', 'key', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.content is string && data.content.size() <= 20000 &&
             data.type in ['dive', 'formula', 'solve'] &&
             data.key is string && data.key.size() <= 1024 &&
             data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.keys().size() == 2 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt == request.time;
    }

    function isValidAttempt(data) {
      return data.keys().hasAll(['topicId', 'score', 'total', 'difficulty', 'date', 'mistakes']) &&
             data.keys().size() == 6 &&
             data.topicId is string && data.topicId.size() <= 100 &&
             data.score is int && data.score >= 0 &&
             data.total is int && data.total > 0 &&
             data.score <= data.total &&
             data.difficulty in ['easy', 'medium', 'hard'] &&
             data.date is timestamp &&
             data.mistakes is list && data.mistakes.size() <= 50;
    }

    // --- Match Blocks ---

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'topic', 'input', 'response', 'isPositive', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.userId == request.auth.uid &&
             data.topic is string && data.topic.size() <= 200 &&
             data.input is string && data.input.size() <= 2000 &&
             data.response is string && data.response.size() <= 20000 &&
             data.isPositive is bool &&
             data.createdAt == request.time;
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming()) && isValidId(feedbackId);
      allow read, update, delete: if false;
    }

    match /ai_cache/{cacheId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidCache(incoming()) && isValidId(cacheId);
      allow update, delete: if false;
    }

    match /users/{userId} {
      // Profiles are sensitive, only owner can read their own
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      match /attempts/{attemptId} {
        // Enforce secure list queries by checking the path variable
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAttempt(incoming());
        // Attempts are immutable to prevent tampering with history
        allow update, delete: if false;
      }
    }
  }
}
