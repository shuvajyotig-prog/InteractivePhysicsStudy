rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      // For standard write operations, mandate email verification
      return isOwner(userId) && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.keys().size() == 2 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt == request.time;
    }

    function isValidAttempt(data) {
      return data.keys().hasAll(['topicId', 'score', 'total', 'difficulty', 'date', 'mistakes']) &&
             data.keys().size() == 6 &&
             data.topicId is string && data.topicId.size() <= 100 &&
             data.score is int && data.score >= 0 &&
             data.total is int && data.total > 0 &&
             data.score <= data.total &&
             data.difficulty in ['easy', 'medium', 'hard'] &&
             data.date == request.time &&
             data.mistakes is list && data.mistakes.size() <= 50;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      // Profiles are sensitive, only owner can read their own
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      match /attempts/{attemptId} {
        // Enforce secure list queries by checking the path variable
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAttempt(incoming());
        // Attempts are immutable to prevent tampering with history
        allow update, delete: if false;
      }
    }
  }
}
